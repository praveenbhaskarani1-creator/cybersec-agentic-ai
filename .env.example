# AWS
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=amazon.titan-embed-text-v1
AWS_BEDROCK_LLM_MODEL_ID=amazon.titan-text-express-v1

# Aurora PostgreSQL (RDS)
POSTGRES_HOST=your-aurora-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=cybersec
POSTGRES_USER=cybersec_user
POSTGRES_PASSWORD=your_password_here

# JWT Auth
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_OT_EVENTS=ot_events_raw
KAFKA_TOPIC_SYSLOG=syslog_events_raw

# RAG
EMBEDDING_DIMENSIONS=1536
RAG_TOP_K=10
RAG_SIMILARITY_THRESHOLD=0.75
RERANKER_TOP_N=3

# External APIs
VIRUSTOTAL_API_KEY=your_key_here
NVD_API_KEY=your_key_here
WORLDVIEW_API_KEY=your_key_here

# App
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false
